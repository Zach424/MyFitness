API_PORT=3100
# Defaults to 127.0.0.1 outside production and 0.0.0.0 in production.
API_HOST=127.0.0.1
AUTH_ENABLED_PROVIDERS=dev
WECHAT_MINI_APP_ID=
WECHAT_MINI_APP_SECRET=
# Non-production test override only; production is pinned to the official WeChat endpoint.
WECHAT_CODE_SESSION_URL=https://api.weixin.qq.com/sns/jscode2session
# End-user H5 Authorization Code + PKCE adapter. Required only when oidc is enabled.
USER_OIDC_ISSUER=https://identity.example.com
USER_OIDC_AUTHORIZATION_URL=https://identity.example.com/oauth2/authorize
USER_OIDC_TOKEN_URL=https://identity.example.com/oauth2/token
USER_OIDC_JWKS_URL=https://identity.example.com/.well-known/jwks.json
USER_OIDC_CLIENT_ID=myfitness-h5
USER_OIDC_CLIENT_SECRET=
USER_OIDC_REDIRECT_URI=http://127.0.0.1:10086/auth/callback
DATABASE_URL=postgresql://myfitness:myfitness_local@127.0.0.1:54329/myfitness
AI_SERVICE_URL=http://127.0.0.1:8001
AI_SERVICE_TOKEN=myfitness-ai-local
AI_SERVICE_TIMEOUT_MS=22000
AI_RUN_STALE_MS=30000
AI_RUN_RECONCILE_POLL_MS=15000
AI_PROVIDER=fixture
AI_MODEL=gpt-5.6-terra
AI_VISION_MODEL=gpt-5.6-terra
AI_VISION_DETAIL=high
AI_REASONING_EFFORT=low
AI_REQUEST_TIMEOUT_SECONDS=20
OPENAI_API_KEY=
PHOTO_UPLOAD_SIGNING_SECRET=replace-with-at-least-32-random-characters
OBJECT_STORAGE_ENDPOINT=http://127.0.0.1:9000
OBJECT_STORAGE_BUCKET=myfitness-private
OBJECT_STORAGE_REGION=us-east-1
OBJECT_STORAGE_ACCESS_KEY_ID=myfitness-minio
OBJECT_STORAGE_SECRET_ACCESS_KEY=myfitness-minio-secret-2026-local
OBJECT_STORAGE_FORCE_PATH_STYLE=true
OBJECT_STORAGE_AUTO_CREATE_BUCKET=true
OBJECT_STORAGE_SSE=none
OBJECT_STORAGE_KMS_KEY_ID=
PHOTO_OBJECT_PREFIX=private-photos
ERASURE_LEDGER_PREFIX=control/erasure-ledger
ERASURE_LEDGER_HASH_SECRET=replace-with-at-least-32-random-characters
DATA_OPERATIONS_WORKER_ENABLED=true
DATA_OPERATIONS_POLL_MS=15000
REDIS_URL=redis://127.0.0.1:63799
RATE_LIMIT_HASH_SECRET=replace-with-at-least-32-random-characters
RATE_LIMIT_KEY_PREFIX=myfitness:rate:v1
OPERATIONS_TOKEN=replace-with-at-least-32-random-characters
TRUST_PROXY_HOPS=0
CORS_ORIGINS=http://127.0.0.1:4173,http://localhost:10086
ADMIN_AUDIT_HASH_SECRET=replace-with-at-least-32-random-characters
ADMIN_SESSION_MINUTES=60
ADMIN_OIDC_ISSUER=https://identity.example.com
ADMIN_OIDC_AUDIENCE=myfitness-admin
ADMIN_OIDC_JWKS_URL=https://identity.example.com/.well-known/jwks.json
MYFITNESS_API_URL=http://127.0.0.1:3100/v1
TARO_APP_API_BASE_URL=http://127.0.0.1:3100/v1
TARO_APP_AUTH_MODE=dev
ADMIN_ENABLE_LOCAL_LOGIN=false
ADMIN_COOKIE_SECURE=true
ADMIN_LOCAL_SUBJECT=local-evidence-operator
