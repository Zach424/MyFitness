# Copy to a secret-managed environment file; never commit populated values.
NODE_ENV=production
API_HOST=0.0.0.0
API_PORT=3100
AUTH_ENABLED_PROVIDERS=wechat,oidc
WECHAT_MINI_APP_ID=wxREPLACE_WITH_REAL_APP_ID
WECHAT_MINI_APP_SECRET=replace-with-secret-manager-reference
USER_OIDC_ISSUER=https://identity.example.com
USER_OIDC_AUTHORIZATION_URL=https://identity.example.com/oauth2/authorize
USER_OIDC_TOKEN_URL=https://identity.example.com/oauth2/token
USER_OIDC_JWKS_URL=https://identity.example.com/.well-known/jwks.json
USER_OIDC_CLIENT_ID=myfitness-h5
USER_OIDC_CLIENT_SECRET=replace-with-secret-manager-reference
USER_OIDC_REDIRECT_URI=https://h5.example.com/auth/callback
DATABASE_URL=postgresql://service:replace@database.internal/myfitness?sslmode=require
AI_SERVICE_URL=https://ai.internal.example.com
AI_SERVICE_TOKEN=replace-with-at-least-32-random-characters
AI_SERVICE_TIMEOUT_MS=22000
AI_RUN_STALE_MS=30000
AI_RUN_RECONCILE_POLL_MS=15000
PHOTO_UPLOAD_SIGNING_SECRET=replace-with-at-least-32-random-characters
OBJECT_STORAGE_ENDPOINT=https://objects.internal.example.com
OBJECT_STORAGE_BUCKET=myfitness-production-private
OBJECT_STORAGE_REGION=replace-with-region
OBJECT_STORAGE_FORCE_PATH_STYLE=false
OBJECT_STORAGE_AUTO_CREATE_BUCKET=false
OBJECT_STORAGE_SSE=AES256
PHOTO_OBJECT_PREFIX=private-photos
ERASURE_LEDGER_PREFIX=control/erasure-ledger
ERASURE_LEDGER_HASH_SECRET=replace-with-at-least-32-random-characters
DATA_OPERATIONS_WORKER_ENABLED=true
DATA_OPERATIONS_POLL_MS=15000
REDIS_URL=rediss://redis.internal:6380
RATE_LIMIT_HASH_SECRET=replace-with-at-least-32-random-characters
RATE_LIMIT_KEY_PREFIX=myfitness:rate:v1
OPERATIONS_TOKEN=replace-with-at-least-32-random-characters
TRUST_PROXY_HOPS=1
CORS_ORIGINS=https://h5.example.com
ADMIN_AUDIT_HASH_SECRET=replace-with-at-least-32-random-characters
ADMIN_SESSION_MINUTES=60
ADMIN_OIDC_ISSUER=https://identity.example.com
ADMIN_OIDC_AUDIENCE=myfitness-admin
ADMIN_OIDC_JWKS_URL=https://identity.example.com/.well-known/jwks.json

# Administrator image runtime settings.
MYFITNESS_API_URL=http://api.internal:3100/v1
ADMIN_ENABLE_LOCAL_LOGIN=false
ADMIN_COOKIE_SECURE=true
ADMIN_OIDC_AUTHORIZATION_URL=https://identity.example.com/oauth2/authorize
ADMIN_OIDC_TOKEN_URL=https://identity.example.com/oauth2/token
ADMIN_OIDC_CLIENT_ID=replace-with-client-id
ADMIN_OIDC_CLIENT_SECRET=replace-with-secret-manager-reference
ADMIN_OIDC_REDIRECT_URI=https://admin.example.com/api/operator/oidc/callback
