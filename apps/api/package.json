{
  "name": "@myfitness/api",
  "version": "0.1.0",
  "private": true,
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "db:migrate": "ts-node src/database/migrate.ts",
    "openapi:generate": "ts-node src/scripts/generate-openapi.ts",
    "preopenapi:generate": "pnpm --filter @myfitness/contracts build && pnpm --filter @myfitness/domain build",
    "start": "node dist/main.js",
    "prestart:dev": "pnpm --filter @myfitness/contracts build && pnpm --filter @myfitness/domain build",
    "start:dev": "ts-node src/main.ts",
    "test": "vitest run src --exclude '**/*.integration.spec.ts'",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@myfitness/contracts": "workspace:*",
    "@myfitness/domain": "workspace:*",
    "@nestjs/common": "11.1.28",
    "@nestjs/core": "11.1.28",
    "@nestjs/platform-express": "11.1.28",
    "@nestjs/swagger": "11.4.6",
    "class-transformer": "0.5.1",
    "class-validator": "0.14.2",
    "pg": "8.22.0",
    "reflect-metadata": "0.2.2",
    "rxjs": "7.8.2",
    "sharp": "0.35.3",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@nestjs/testing": "11.1.28",
    "@types/node": "24.13.3",
    "@types/pg": "8.20.0",
    "@types/supertest": "7.2.1",
    "prettier": "3.6.2",
    "supertest": "7.2.2",
    "ts-node": "10.9.2",
    "typescript": "5.9.3",
    "vitest": "4.1.10"
  }
}
