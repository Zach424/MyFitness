{
  "name": "myfitness",
  "version": "0.1.0",
  "private": true,
  "description": "MyFitness / 衡迹 multi-end fitness record and AI planning product",
  "packageManager": "pnpm@11.9.0",
  "engines": {
    "node": ">=20.18.0"
  },
  "scripts": {
    "build": "pnpm -r --if-present build",
    "build:h5": "pnpm --filter @myfitness/client build:h5",
    "build:weapp": "pnpm --filter @myfitness/client build:weapp",
    "build:api": "pnpm --filter @myfitness/api... build",
    "db:up": "docker compose -f infra/local/compose.yaml up -d --wait",
    "db:down": "docker compose -f infra/local/compose.yaml down",
    "db:migrate": "pnpm --filter @myfitness/api db:migrate",
    "dev:api": "pnpm --filter @myfitness/api start:dev",
    "dev:h5": "pnpm --filter @myfitness/client dev:h5",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "typecheck": "pnpm --filter @myfitness/contracts build && pnpm --filter @myfitness/domain build && pnpm -r --if-present typecheck"
  },
  "devDependencies": {
    "prettier": "^3.6.2",
    "typescript": "5.9.3",
    "vitest": "4.1.10"
  }
}
