{
  "name": "myfitness",
  "version": "0.1.0",
  "private": true,
  "description": "MyFitness / 衡迹 multi-end fitness record and AI planning product",
  "packageManager": "pnpm@11.9.0",
  "engines": {
    "node": ">=20.18.0"
  },
  "scripts": {
    "audit:prod": "pnpm audit --prod --audit-level high",
    "build": "pnpm -r --if-present build",
    "build:admin": "pnpm --filter @myfitness/admin... build",
    "build:h5": "pnpm --filter @myfitness/client build:h5",
    "build:weapp": "pnpm --filter @myfitness/client build:weapp",
    "build:api": "pnpm --filter @myfitness/api... build",
    "db:up": "docker compose -f infra/local/compose.yaml up -d --wait",
    "db:down": "docker compose -f infra/local/compose.yaml down",
    "db:migrate": "pnpm --filter @myfitness/api db:migrate",
    "dev:api": "pnpm --filter @myfitness/api start:dev",
    "dev:admin": "pnpm --filter @myfitness/admin dev",
    "dev:h5": "pnpm --filter @myfitness/client dev:h5",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "preview:h5": "node scripts/serve-h5.mjs",
    "ops:verify-backup-restore": "pnpm --filter @myfitness/api ops:verify-backup-restore",
    "ops:verify-production-config": "pnpm --filter @myfitness/api ops:verify-production-config",
    "deploy:verify": "node scripts/verify-deployment.mjs",
    "deploy:smoke": "node scripts/run-deployment-smoke.mjs",
    "release:verify": "node scripts/release-manifest.mjs verify",
    "test": "vitest run",
    "test:ai": "python -m pytest services/ai/tests -q",
    "eval:ai": "pnpm --filter @myfitness/contracts build && pnpm --filter @myfitness/domain build && node scripts/run-ai-evals.mjs",
    "eval:food-photo": "pnpm --filter @myfitness/contracts build && pnpm --filter @myfitness/domain build && node scripts/run-food-photo-evals.mjs",
    "test:e2e": "playwright test",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "typecheck": "pnpm --filter @myfitness/contracts build && pnpm --filter @myfitness/domain build && pnpm -r --if-present typecheck"
  },
  "devDependencies": {
    "@aws-sdk/client-s3": "3.1090.0",
    "@playwright/test": "1.61.1",
    "@types/pg": "8.20.0",
    "pg": "8.22.0",
    "prettier": "^3.6.2",
    "typescript": "5.9.3",
    "vite": "8.1.5",
    "vitest": "4.1.10"
  }
}
