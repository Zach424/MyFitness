    "/v1/me/onboarding": {
      "put": {
        "operationId": "OnboardingController_upsert",
        "parameters": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "adultConfirmed": { "type": "boolean", "enum": [true] },
                  "profile": {
                    "type": "object",
                    "properties": {
                      "displayName": { "type": "string", "minLength": 1, "maxLength": 40 },
                      "ageBand": {
                        "type": "string",
                        "enum": ["18_24", "25_34", "35_44", "45_54", "55_64", "65_plus"]
                      },
                      "sexForCalculations": {
                        "type": "string",
                        "enum": ["female", "male", "unspecified"]
                      },
                      "height": {
                        "type": "object",
                        "properties": {
                          "value": { "type": "number", "minimum": 0, "exclusiveMinimum": true },
                          "unit": { "type": "string", "enum": ["cm", "in"] }
                        },
                        "required": ["value", "unit"],
                        "additionalProperties": false
                      },
                      "unitSystem": { "type": "string", "enum": ["metric", "imperial"] },
                      "timezone": { "type": "string", "minLength": 1, "maxLength": 64 }
                    },
                    "required": [
                      "displayName",
                      "ageBand",
                      "sexForCalculations",
                      "height",
                      "unitSystem",
                      "timezone"
                    ],
                    "additionalProperties": false
                  },
                  "goal": {
                    "type": "object",
                    "properties": {
                      "primaryGoal": {
                        "type": "string",
                        "enum": ["fat_loss", "muscle_gain", "fitness", "habit"]
                      },
                      "experience": {
                        "type": "string",
                        "enum": ["beginner", "intermediate", "advanced"]
                      },
                      "availableDays": {
                        "minItems": 1,
                        "maxItems": 7,
                        "type": "array",
                        "items": {
                          "type": "string",
                          "enum": ["mon", "tue", "wed", "thu", "fri", "sat", "sun"]
                        }
                      },
                      "sessionMinutes": { "type": "integer", "minimum": 15, "maximum": 180 },
                      "equipment": {
                        "minItems": 1,
                        "type": "array",
                        "items": {
                          "type": "string",
                          "enum": [
                            "bodyweight",
                            "dumbbells",
                            "barbell",
                            "machines",
                            "bands",
                            "cardio"
                          ]
                        }
                      },
                      "dietaryPreferences": {
                        "minItems": 1,
                        "type": "array",
                        "items": {
                          "type": "string",
                          "enum": ["none", "vegetarian", "vegan", "halal", "lactose_free"]
                        }
                      }
                    },
                    "required": [
                      "primaryGoal",
                      "experience",
                      "availableDays",
                      "sessionMinutes",
                      "equipment",
                      "dietaryPreferences"
                    ],
                    "additionalProperties": false
                  },
                  "risk": {
                    "type": "object",
                    "properties": {
                      "flags": {
                        "type": "array",
                        "items": {
                          "type": "string",
                          "enum": [
                            "chest_pain",
                            "fainting",
                            "uncontrolled_condition",
                            "acute_injury",
                            "pregnancy",
                            "eating_disorder_history"
                          ]
                        }
                      },
                      "acknowledged": { "type": "boolean", "enum": [true] }
                    },
                    "required": ["flags", "acknowledged"],
                    "additionalProperties": false
                  },
                  "consents": {
                    "type": "object",
                    "properties": {
                      "terms": {
                        "type": "object",
                        "properties": {
                          "accepted": { "type": "boolean", "enum": [true] },
                          "version": { "type": "string", "enum": ["2026-07-18"] }
                        },
                        "required": ["accepted", "version"],
                        "additionalProperties": false
                      },
                      "privacy": {
                        "type": "object",
                        "properties": {
                          "accepted": { "type": "boolean", "enum": [true] },
                          "version": { "type": "string", "enum": ["2026-07-18"] }
                        },
                        "required": ["accepted", "version"],
                        "additionalProperties": false
                      },
                      "healthData": {
                        "type": "object",
                        "properties": {
                          "accepted": { "type": "boolean", "enum": [true] },
                          "version": { "type": "string", "enum": ["2026-07-18"] }
                        },
                        "required": ["accepted", "version"],
                        "additionalProperties": false
                      }
                    },
                    "required": ["terms", "privacy", "healthData"],
                    "additionalProperties": false
                  },
                  "expectedRevision": {
                    "type": "integer",
                    "minimum": 0,
                    "maximum": 9007199254740991
                  }
                },
                "required": ["adultConfirmed", "profile", "goal", "risk", "consents"],
                "additionalProperties": false
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "userId": {
