                    "metric",
                    "canonicalValue",
                    "canonicalUnit",
                    "displayValue",
                    "displayUnit",
                    "source",
                    "confidence",
                    "status",
                    "occurredAt",
                    "timezone",
                    "revision",
                    "createdAt",
                    "updatedAt"
                  ],
                  "additionalProperties": false
                }
              }
            }
          },
          "400": { "description": "Contract, provenance, timezone, unit or range is invalid." },
          "409": { "description": "Idempotency key was reused with different content." }
        },
        "summary": "Create an idempotent body or recovery measurement",
        "tags": ["health records"]
