{
  "openapi": "3.0.0",
  "paths": {
    "/v1/auth/dev/session": {
      "post": {
        "description": "Disabled when NODE_ENV=production. Replace with WeChat/phone verification.",
        "operationId": "AuthController_createDevSession",
        "parameters": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "subject": {
                    "type": "string",
                    "minLength": 3,
                    "maxLength": 128,
                    "pattern": "^[A-Za-z0-9._:-]+$"
                  }
                },
                "required": ["subject"],
                "additionalProperties": false
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "accessToken": { "type": "string", "minLength": 32 },
                    "userId": {
                      "type": "string",
                      "format": "uuid",
                      "pattern": "^([0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-8][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}|00000000-0000-0000-0000-000000000000|ffffffff-ffff-ffff-ffff-ffffffffffff)$"
                    },
                    "expiresAt": {
                      "type": "string",
                      "format": "date-time",
                      "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z|([+-](?:[01]\\d|2[0-3]):[0-5]\\d)))$"
                    }
                  },
                  "required": ["accessToken", "userId", "expiresAt"],
                  "additionalProperties": false
                }
              }
            }
          }
        },
        "summary": "Create a local-only opaque session",
        "tags": ["authentication"]
      }
    },
    "/v1/health": {
      "get": {
        "operationId": "HealthController_readiness",
        "parameters": [],
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "required": ["status", "service", "database", "timestamp"],
                  "properties": {
                    "status": { "type": "string", "enum": ["ok"] },
                    "service": { "type": "string", "example": "myfitness-api" },
                    "database": { "type": "string", "enum": ["up"] },
                    "timestamp": { "type": "string", "format": "date-time" }
                  }
                }
              }
            }
          }
        },
        "summary": "Check API and database readiness",
        "tags": ["system"]
      }
    },
